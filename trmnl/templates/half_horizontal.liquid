<!--
  TRMNL Solar System Viewer — Half Horizontal Layout
  Compact solar system diagram with planet distances.
-->
<div class="layout layout--col gap--space-between">
  <div class="columns">
    <div class="column">
      <div class="markdown">
        <h2>Solar System</h2>
      </div>
    </div>
  </div>

  <div class="columns">
    <div class="column" style="flex:2">
      <div style="position:relative;width:{{ half.width }}px;height:{{ half.height }}px">
        {% for orbit in half.orbits %}
        <div style="position:absolute;left:{{ orbit.left }}px;top:{{ orbit.top }}px;width:{{ orbit.size }}px;height:{{ orbit.size }}px;border-radius:50%;border:1px dashed #ccc"></div>
        {% endfor %}
        <div style="position:absolute;left:{{ half.cx | minus: 4 }}px;top:{{ half.cy | minus: 4 }}px;width:8px;height:8px;border-radius:50%;background:#000"></div>
        {% for p in half.planets %}
        <div style="position:absolute;left:{{ p.left }}px;top:{{ p.top }}px;width:{{ p.dot }}px;height:{{ p.dot }}px;border-radius:50%;background:#000"></div>
        <div style="position:absolute;left:{{ p.label_left }}px;top:{{ p.label_top }}px;transform:translateX(-50%);font-size:7px;white-space:nowrap">{{ p.abbrev }}</div>
        {% endfor %}
      </div>
    </div>
    <div class="column" style="flex:1">
      {% for planet in planets %}
      <div style="margin-bottom:2px">
        <span style="font-size:11px;font-weight:bold">{{ planet.abbrev }}</span>
        <span style="font-size:10px">{{ planet.distance_au }} AU</span>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="columns">
    <div class="column">
      <span class="label label--gray">{{ date }}</span>
    </div>
  </div>
</div>
