<!--
  TRMNL Solar System Viewer — Full Screen Layout
  Shows planet positions around the Sun with distance data.
-->
<div class="layout layout--col">
  <div class="columns">
    <div class="column">
      <div class="markdown">
        <h1>Solar System</h1>
      </div>
    </div>
    <div class="column" style="text-align:right">
      <span class="label label--gray">{{ date }} {{ time_utc }}</span>
    </div>
  </div>

  <div class="columns">
    <div class="column" style="flex:3">
      <div style="position:relative;width:{{ full.width }}px;height:{{ full.height }}px">
        {% for orbit in full.orbits %}
        <div style="position:absolute;left:{{ orbit.left }}px;top:{{ orbit.top }}px;width:{{ orbit.size }}px;height:{{ orbit.size }}px;border-radius:50%;border:1px dashed #ccc"></div>
        {% endfor %}
        <div style="position:absolute;left:{{ full.cx | minus: 5 }}px;top:{{ full.cy | minus: 5 }}px;width:10px;height:10px;border-radius:50%;background:#000"></div>
        {% for p in full.planets %}
        {% if p.is_earth %}
        <div style="position:absolute;left:{{ p.ring_left }}px;top:{{ p.ring_top }}px;width:{{ p.ring_size }}px;height:{{ p.ring_size }}px;border-radius:50%;border:1px solid #000"></div>
        {% endif %}
        <div style="position:absolute;left:{{ p.left }}px;top:{{ p.top }}px;width:{{ p.dot }}px;height:{{ p.dot }}px;border-radius:50%;background:#000"></div>
        <div style="position:absolute;left:{{ p.label_left }}px;top:{{ p.label_top }}px;transform:translateX(-50%);font-size:8px;white-space:nowrap">{{ p.name }}</div>
        {% endfor %}
      </div>
    </div>
    <div class="column" style="flex:1">
      {% for planet in planets %}
      <div class="meta" style="margin-bottom:4px">
        <span class="title title--small">{{ planet.name }}</span>
        <span class="description">{{ planet.distance_au }} AU</span>
      </div>
      {% endfor %}
    </div>
  </div>
</div>
