<!--
  TRMNL Solar System Viewer — Quadrant Layout
  Compact solar system diagram.
-->
<div class="layout layout--col gap--space-between">
  <div class="columns">
    <div class="column">
      <span class="title title--small">Planets</span>
    </div>
  </div>
  <div class="columns">
    <div class="column">
      <div style="position:relative;width:{{ quadrant.width }}px;height:{{ quadrant.height }}px">
        {% for orbit in quadrant.orbits %}
        <div style="position:absolute;left:{{ orbit.left }}px;top:{{ orbit.top }}px;width:{{ orbit.size }}px;height:{{ orbit.size }}px;border-radius:50%;border:1px dashed #ccc"></div>
        {% endfor %}
        <div style="position:absolute;left:{{ quadrant.cx | minus: 4 }}px;top:{{ quadrant.cy | minus: 4 }}px;width:8px;height:8px;border-radius:50%;background:#000"></div>
        {% for p in quadrant.planets %}
        <div style="position:absolute;left:{{ p.left }}px;top:{{ p.top }}px;width:{{ p.dot }}px;height:{{ p.dot }}px;border-radius:50%;background:#000"></div>
        <div style="position:absolute;left:{{ p.label_left }}px;top:{{ p.label_top }}px;transform:translateX(-50%);font-size:7px;white-space:nowrap">{{ p.abbrev }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
  <div class="columns">
    <div class="column">
      <span class="label label--gray">{{ date }}</span>
    </div>
  </div>
</div>
