<!--
  TRMNL Solar System Viewer — Full Screen Layout
-->
<div class="layout layout--col">
  <div class="columns">
    <div class="column">
      <div class="markdown">
        <h1>Solar System</h1>
      </div>
    </div>
    <div class="column" style="text-align:right">
      <span class="label label--gray">{{ date }} {{ time_utc }}</span>
    </div>
  </div>

  <div class="columns">
    <div class="column" style="flex:7">
      <img src="data:image/svg+xml;base64,{{ img_full }}" width="560" height="430" />
    </div>
    <div class="column" style="flex:3">
      {% for planet in planets %}
      <div class="meta" style="margin-bottom:4px">
        <span class="title title--small">{{ planet.name }}</span>
        <span class="description">{{ planet.distance }} AU</span>
      </div>
      {% endfor %}
    </div>
  </div>
</div>
